rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/admin/$(request.auth.token.email));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Rate limiting helper - throttle writes to prevent abuse
    // Limits: max 10 writes per minute per user for most collections
    function isNotRateLimited() {
      return request.time > resource.data.lastWriteTime + duration.value(6, 's');
    }
    
    // Products - Public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow authenticated users to update stock when placing/cancelling orders
      allow update: if isSignedIn() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt']) &&
                       (request.resource.data.stock < resource.data.stock || // Placing order (reduce)
                        request.resource.data.stock > resource.data.stock);  // Cancelling order (restore)
    }
    
    // Admin collection (email-based) - Read for authenticated users, write disabled
    match /admin/{email} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    // User data - Owner or admin
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // Carts - Owner only
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Wishlists - Owner only
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Orders - Owner or admin
    match /orders/{orderId} {
      allow read: if isSignedIn() && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid;
      // Allow users to cancel their own pending/processing orders
      allow update: if isAdmin() || 
                       (isSignedIn() && 
                        resource.data.userId == request.auth.uid &&
                        (resource.data.status == 'pending' || resource.data.status == 'processing') &&
                        request.resource.data.status == 'cancelled' &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt', 'cancellationReason', 'cancelledBy']));
      allow delete: if isAdmin();
    }
    
    // Reviews - Authenticated users can create, owner can update/delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // Coupons - Admin only
    match /coupons/{couponId} {
      allow read, write: if isAdmin();
    }
    
    // Activity Logs - Admin only
    match /activityLogs/{logId} {
      allow read, write: if isAdmin();
    }
    
    // Stock History - Admin only, users can create entries when placing/cancelling orders
    match /stockHistory/{historyId} {
      allow read, write: if isAdmin();
      // Allow authenticated users to create stock history for order operations
      allow create: if isSignedIn() && 
                       ((request.resource.data.reason == 'Order Placed' && request.resource.data.change < 0) ||
                        (request.resource.data.reason == 'Order Cancelled' && request.resource.data.change > 0));
    }
  }
}
